<?xml version="1.0" encoding="utf-8"?>
<!-- Shared config. The page to open (server_url) is per-flavor; see
     src/tv/res/values/config.xml and src/watch/res/values/config.xml.
     Edit these, then rebuild with ./build.sh (produces both APKs). -->
<resources>
    <string name="screen_name" translatable="false">Living Room TV</string>
    <!-- Hide the system bars and lock to landscape (the tv/watch appliance look).
         The phone flavor overrides this to false; see src/phone/res/values/config.xml. -->
    <bool name="immersive">true</bool>
</resources>
